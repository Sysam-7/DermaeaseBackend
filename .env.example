# Copy to .env

PORT=5000
MONGO_URI=mongodb://localhost:27017/dermaease
JWT_SECRET=change-me
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:5000
SESSION_SECRET=change-me

# Google OAuth — Authorized redirect URI must match EXACTLY (include /api):
# http://localhost:5000/api/auth/google/callback
# If you only use the Vite dev server (port 3000) for OAuth callback, also add:
# http://localhost:3000/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# Khalti ePayment (sandbox: https://dev.khalti.com/api/v2)
KHALTI_SECRET_KEY=
KHALTI_BASE_URL=https://dev.khalti.com/api/v2
KHALTI_RETURN_URL=http://localhost:3000/patient/payment/khalti/return
# Fee in paisa (500 NPR = 50000). Min 1000.
# APPOINTMENT_FEE_PAISA=50000
